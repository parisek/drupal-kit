/vendor/
/web/
/recipes/
composer.lock
coverage.xml
.phpunit.result.cache
.phpunit.cache/
.DS_Store
# drupal/core-composer-scaffold generates these at project root during
# `composer install` (we're a library, not a site project).
/.editorconfig
/cov/
# Ignore docs/ contents (not the dir itself, so the adr/ negation below can re-include).
/docs/*
# ADRs are the one committed thing under docs/ — keep them tracked.
!/docs/adr/
