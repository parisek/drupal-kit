{
    "name": "parisek/custom-components",
    "type": "drupal-custom-module",
    "description": "Provides functionality for components.",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1",
        "drupal/components": "^3.2",
        "drupal/config_pages": "^2.19",
        "drupal/core": "^10 || ^11",
        "drupal/extra_field": "^3.0",
        "drupal/twig_real_content": "^1.0",
        "drupal/twig_tweak": "^3.4",
        "parisek/twig-typography": "^1.2"
    },
    "suggest": {
        "drupal/commerce": "Enables commerce_product entity rendering in EntityHelper.",
        "drupal/office_hours": "Enables office_hours field rendering in EntityHelper."
    },
    "require-dev": {
        "phpunit/phpunit": "^10",
        "phpstan/phpstan": "^1.8",
        "mglaman/phpstan-drupal": "^1.3",
        "drupal/core-dev": "^11"
    },
    "autoload": {
        "psr-4": {
            "Drupal\\custom_components\\": "src/"
        }
    },
    "extra": {
        "installer-name": "custom_components"
    },
    "repositories": [{
        "name": "drupal",
        "type": "composer",
        "url": "https://packages.drupal.org/8"
    }],
    "config": {
        "allow-plugins": {
            "drupal/core-composer-scaffold": false,
            "phpstan/extension-installer": false,
            "dealerdirect/phpcodesniffer-composer-installer": false
        }
    }
}
